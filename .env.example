# Gmail Configuration
imap_server=imap.gmail.com
userid=your@gmail.com

# Mailbox settings
mailbox=INBOX
port=8000
refresh_seconds=300
data_dir=data
server_baseurl=http://localhost:8000

# Bind address for the HTTP server
# Default: 127.0.0.1 (localhost only). Set to 0.0.0.0 to listen on all interfaces.
bind_address=0.0.0.0

# Internal RSS Reader (optional)
# Set to 'true' to enable internal article viewer at /article/{feed}/{guid}
# When enabled, RSS feed links point to internal reader instead of external websites
# Default: false (links point to sender's domain)
enable_internal_reader=false

# OpenTelemetry / SigNoz (optional)
# Set OTEL_EXPORTER_OTLP_ENDPOINT to your collector URL to enable traces,
# metrics and logs export. When left blank, OTel is disabled entirely and
# the app runs without the opentelemetry-instrument wrapper.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-collector.example.com
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,service.version=0.1.1
